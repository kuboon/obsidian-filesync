FILESYNC_APPID=obsidian-filesync
FILESYNC_ROOMID=your-room-id
FILESYNC_PASSPHRASE=your-shared-secret
FILESYNC_RELAYS=wss://exp-relay.vrtmrz.net/
FILESYNC_PEER_NAME=my-server
# Server root directory. Scopes become subdirectories under this.
# e.g. scope "agent-a" → ./vault/agent-a/
FILESYNC_VAULT_DIR=./vault
FILESYNC_AUTO_ACCEPT=.*
